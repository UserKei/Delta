{
  "name": "@repo/core",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./fa": {
      "types": "./dist/fa/index.d.ts",
      "import": "./dist/fa/index.js",
      "require": "./dist/fa/index.cjs"
    },
    "./ll1": {
      "types": "./dist/ll1/index.d.ts",
      "import": "./dist/ll1/index.js",
      "require": "./dist/ll1/index.cjs"
    },
    "./lr": {
      "types": "./dist/lr/index.d.ts",
      "import": "./dist/lr/index.js",
      "require": "./dist/lr/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/fa/index.ts src/ll1/index.ts src/lr/index.ts --format cjs,esm --dts --clean && node scripts/fix-dts-runtime-refs.mjs",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/lodash-es": "^4.17.12",
    "bun-types": "^1.3.8",
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "fast-deep-equal": "^3.1.3",
    "lodash-es": "^4.17.23"
  }
}
