{
  // 1. 继承：引入远程或本地仓库中通用的基础配置（如：严格模式开关、目标版本等）
  // 这能保证团队内部多个项目的编译标准保持一致
  "extends": "@repo/typescript-config/base.json",

  "compilerOptions": {
    // 2. 输出目录：编译后的 .js 文件存放的位置
    "outDir": "./dist",

    // 3. 源码根目录：告知编译器源代码的起始位置，用以在输出时保持相同的目录结构
    "rootDir": "./src"
  },

  // 4. 包含范围：指定哪些文件需要被编译
  // 这里使用了通配符，表示编译 src 文件夹下的所有子文件夹中的 .ts 文件
  "include": ["src/**/*.ts"],

  // 5. 排除范围：明确告诉编译器跳过哪些文件夹
  // node_modules（第三方库）和 dist（已生成的代码）通常不需要再次被编译
  "exclude": ["node_modules", "dist"]
}