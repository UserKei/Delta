{
  "include": ["src/**/*", "src/**/*.vue"],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "useDefineForClassFields": true,
    "strict": true,
    "jsx": "preserve",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noEmit": true,
    "composite": false,
    "baseUrl": ".",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@repo/core": ["../core/dist/index.d.ts"],
      "@repo/ll1-service": ["../ll1-service/src/index.ts"],
      "@repo/shared-types": ["../shared-types/dist/index.d.ts"]
    }
  }
}
