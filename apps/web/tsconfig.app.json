{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "paths": {
      "@/*": ["./src/*"],
      "@repo/fa-judge": ["../../packages/fa-judge/dist/index.d.ts"],
      "@repo/ll1-judge": ["../../packages/ll1-judge/dist/index.d.ts"],
      "@repo/lr-judge": ["../../packages/lr-judge/dist/index.d.ts"],
      "@repo/shared-types": ["../../packages/shared-types/dist/index.d.ts"]
    }
  }
}
